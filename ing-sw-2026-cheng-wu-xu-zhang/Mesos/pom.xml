<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>it.polimi</groupId>
  <artifactId>Mesos</artifactId>
  <version>1.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>Mesos</name>
  <url>http://maven.apache.org</url>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>16</maven.compiler.release>
    <javafx.version>25</javafx.version>
  </properties>

  <dependencies>

    <!-- JavaFX Dependencies -->
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-controls</artifactId>
      <version>${javafx.version}</version>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-fxml</artifactId>
      <version>${javafx.version}</version>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-graphics</artifactId>
      <version>${javafx.version}</version>
    </dependency>

    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.12.1</version>
      <scope>test</scope>
    </dependency>

    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>2.15.2</version>
    </dependency>

    <!-- MySQL JDBC driver (used for persisting match scores when enabled). -->
    <dependency>
      <groupId>com.mysql</groupId>
      <artifactId>mysql-connector-j</artifactId>
      <version>8.4.0</version>
    </dependency>

  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.4</version>
        <configuration>
          <argLine>@{argLine} --enable-native-access=ALL-UNNAMED</argLine>
          <forkCount>1</forkCount>
          <systemPropertyVariables>
            <mesos.db.enabled>false</mesos.db.enabled>
          </systemPropertyVariables>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.openjfx</groupId>
        <artifactId>javafx-maven-plugin</artifactId>
        <version>0.0.8</version>
        <configuration>
          <mainClass>it.polimi.Network.Client.Launcher</mainClass>
          <options>
            <option>--enable-native-access=ALL-UNNAMED</option>
          </options>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <version>0.8.13</version>
        <configuration>
          <excludes>
            <exclude>it/polimi/Network/Client/ClientGuiMain*</exclude>
            <exclude>it/polimi/Network/Client/CardNode*</exclude>
            <exclude>it/polimi/Network/Client/ImageLoader*</exclude>
            <exclude>it/polimi/Network/Client/Launcher*</exclude>
            <exclude>it/polimi/Network/Client/ClientMain*</exclude>
            <exclude>it/polimi/Network/Client/ClientThread*</exclude>
            <exclude>it/polimi/Network/Client/RmiClientAdapter*</exclude>
            <exclude>it/polimi/Network/Server/ServerMain*</exclude>
            <exclude>it/polimi/Network/Tools/CheckRmi*</exclude>
            <exclude>it/polimi/Network/Client/ConsoleTuiRenderer*</exclude>
            <exclude>it/polimi/Network/Server/ClientHandler*</exclude>
            <exclude>it/polimi/Network/Server/Lobby*</exclude>
            <exclude>it/polimi/Network/Server/GameRoom*</exclude>
            <exclude>it/polimi/Network/Server/RMI*</exclude>
            <exclude>it/polimi/Network/RMI*</exclude>
            <exclude>it/polimi/Game/Persistence*</exclude>
          </excludes>
        </configuration>
        <executions>
          <execution>
            <goals>
              <goal>prepare-agent</goal>
            </goals>
          </execution>
          <execution>
            <id>report</id>
            <phase>test</phase>
            <goals>
              <goal>report</goal>
            </goals>
          </execution>
          <execution>
            <id>check</id>
            <phase>verify</phase>
            <goals>
              <goal>check</goal>
            </goals>
            <configuration>
              <rules>
                <rule>
                  <element>BUNDLE</element>
                  <limits>
                    <limit>
                      <counter>INSTRUCTION</counter>
                      <value>COVEREDRATIO</value>
                      <minimum>0.85</minimum>
                    </limit>
                    <limit>
                      <counter>METHOD</counter>
                      <value>COVEREDRATIO</value>
                      <minimum>0.90</minimum>
                    </limit>
                  </limits>
                </rule>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
